{
  "name": "service",
  "version": "1.0.0",
  "description": "",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npm run lint:oxlint && npm run lint:eslint",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "lint:oxlint": "oxlint . --deny-warnings",
    "lint:oxlint:fix": "oxlint . --fix --deny-warnings",
    "lint:fix": "npm run lint:eslint:fix && npm run lint:oxlint:fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "fix": "npm run format && npm run lint:fix",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test",
    "ci": "npm run check && npm run build",
    "audit": "npm audit --omit=dev",
    "audit:all": "npm audit",
    "deps:outdated": "npm outdated"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@apollo/server": "^4.13.0",
    "@nestjs/apollo": "13.1.0",
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/graphql": "^13.2.1",
    "@nestjs/platform-express": "^11.1.9",
    "graphql": "^16.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/testing": "^11.1.9",
    "@swc/core": "^1.15.3",
    "@types/node": "^25.5.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "oxlint": "^1.63.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.0"
  }
}

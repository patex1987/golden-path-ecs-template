# Copy this template when the Postgres e2e test runner itself runs inside the
# Docker Compose network.
# Render to env_files/in-docker/test-e2e-postgres.env.
#
# This profile is destructive: the e2e harness drops and recreates the public
# schema before running migrations and seeds.
#
# Use postgres because that is the Compose service name on the internal Compose
# network. Do not use this profile from host-based npm or WebStorm runs.

MOVIE_RESERVATION_E2E_DATABASE=external
TEST_DATABASE_URL=postgres://movie_reservation_service:movie_reservation_service@postgres:5432/movie_reservation_service

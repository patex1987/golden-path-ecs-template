# Copy this template when you want to run or debug Postgres e2e tests from the
# host machine against the Docker Compose Postgres database.
# Render to env_files/local/test-e2e-postgres.env.
#
# This profile is destructive: the e2e harness drops and recreates the public
# schema before running migrations and seeds.
#
# Use localhost because npm/WebStorm runs the test process on the host.

MOVIE_RESERVATION_E2E_DATABASE=external
TEST_DATABASE_URL=postgres://movie_reservation_service:movie_reservation_service@localhost:5432/movie_reservation_service

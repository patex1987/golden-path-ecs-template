# Copy this template when running the Vite frontend on the host machine.
# Render to env_files/local/local-dev.env for npm run dev.
#
# Values with the VITE_ prefix are browser-visible. Do not put real secrets in
# this file or in rendered frontend env files.

# Vite dev-server proxy target for browser requests to /graphql.
VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# Optional: bypass the Vite proxy and call a browser-visible GraphQL URL
# directly. Leave unset for the normal local proxy path.
# VITE_GRAPHQL_URL=http://127.0.0.1:3001/graphql

# Optional local-dev only bearer value for local auth experiments.
# This is visible to browser code. It is not a secret and is ignored outside
# Vite dev mode by the frontend GraphQL client.
# Local fixed-user backend profiles do not need it. Local JWT profiles can use
# a JWT-shaped value that the backend decodes without production validation.
# VITE_DEMO_BEARER_TOKEN=
